# AWS RDS
DB_USER=postgres
DB_PASSWORD=YOUR_RDS_PASSWORD
DB_HOST=myappdb.xxxxx.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=investlive

# AWS S3
AWS_REGION=ap-south-1
S3_BUCKET=myapp-production-files

# Only include keys if not using IAM role
AWS_ACCESS_KEY_ID=YOUR_PROD_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_PROD_SECRET